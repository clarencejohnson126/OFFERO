# Offero — Beispiel-Umgebung. KEINE echten Werte hier (Constitution Art. III).
# Kopiere nach .env.local (gitignored) und fülle die Werte. Modell-IDs gehören NICHT
# hierher — das KI-Routing lebt in packages/core/ai (keine hartcodierten Modell-IDs).

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=offero.app

# ── Supabase (EU-Region, Constitution Art. III) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Offero-Tabellen liegen in einem eigenen Postgres-Schema (Projekt ist ggf. geteilt).
SUPABASE_DB_SCHEMA=offero

# ── KI-Text: Claude / Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── KI-Bild: Google Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Zahlung: Stripe (Web) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Medien: Video (FFmpeg-Lite) ──────────────────────────────────────────────
# Optional. Default: System-ffmpeg im PATH.
FFMPEG_PATH=
