# Offero — Beispiel-Umgebung. KEINE echten Werte hier (Constitution Art. III).
# Kopiere nach .env.local (gitignored) und fülle die Werte. Modell-IDs gehören NICHT
# hierher — das KI-Routing lebt in packages/core/ai (keine hartcodierten Modell-IDs).

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=offero.app

# ── Supabase (EU-Region, Constitution Art. III) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Offero-Tabellen liegen im dedizierten Postgres-Schema `offero` (getrennt von Alt-Apps, ADR 0006).
SUPABASE_DB_SCHEMA=offero

# ── KI-Text: Claude / Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── KI-Bild: Google Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Zahlung: Stripe (Web) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Medien: Video (FFmpeg-Lite) ──────────────────────────────────────────────
# Optional. Default: System-ffmpeg im PATH.
FFMPEG_PATH=

# ── Job-Link-Scraping: Anti-Bot/Cloudflare (Produktion) ──────────────────────
# Bright Data Web Unlocker — 5.000 Abrufe/Monat dauerhaft gratis. Zone einmalig im
# Dashboard anlegen (Typ „Unlocker API"); Default-Zonenname web_unlocker1.
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=web_unlocker1
# Lokaler Browser-Fallback über CDP (nur Lokal-Entwicklung, nicht für Produktion).
# Lokal genügt BU_CDP_URL aus der Shell; hier für Produktion leer lassen.
# Ohne Bright Data: geblockte Portale nudgen den Nutzer zum Anzeigentext-Einfügen.
BROWSER_FETCH_CDP_URL=
